# Local dev secrets for `wrangler dev` / vite. Copy to `.dev.vars` (gitignored)
# and fill in. For production, set secrets via `wrangler secret put NAME`.

# --- Google Maps (server-side, src/worker/geo.ts) ---
#   - Places API (New)   — address autocomplete
#   - Routes API         — most-direct driving distance
# Enable BOTH APIs on the key, and set Application restriction to "None"
# (the Worker calls server-to-server, so HTTP-referrer restriction would block it).
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Auth ---
# Production authentication is handled by Cloudflare Access (Zero Trust) in front
# of troop10rwc.org; the Worker verifies the Access JWT (CF_ACCESS_TEAM_DOMAIN /
# CF_ACCESS_AUD are set in wrangler.jsonc vars). There is no Access locally, so:
# DEV ONLY — treat every request as a fixed dev user. NEVER set in production.
DEV_AUTH_BYPASS=1

# Tells the Worker to serve assets the Vite-dev way (prefixed paths).
ENVIRONMENT=development
